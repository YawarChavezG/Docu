# ═══════════════════════════════════════════════════════════════
# COFAR SGD — Variables de entorno para STACK BACKUP (paralelo)
# Levanta un entorno AISLADO del original en puertos 8081/5174/...
# Misma BD (snapshot), mismo codigo, distinto networking/volumenes.
#
# Generado: 2026-06-16 sesion 10 (pre-refactor Parametrizacion.js)
# Ver docs/PR/BACKUP-PARALELO.md
# ═══════════════════════════════════════════════════════════════

# ─── Proyecto ───
PROJECT_NAME=cofar-sgd-bk
ENVIRONMENT=development-backup
TZ=America/La_Paz

# ─── Puertos host BACKUP (diferentes del original 8080/5173/...) ───
HOST_PORT_NGINX=8081
HOST_PORT_FRONTEND=5174
HOST_PORT_BACKEND=18001
HOST_PORT_POSTGRES=25433
HOST_PORT_REDIS=26380

# ─── PostgreSQL (DB distinta del original `sgd`) ───
POSTGRES_USER=sgd
POSTGRES_PASSWORD=sgd_dev_only_change_in_prod
POSTGRES_DB=sgd_backup

# ─── Redis ───
REDIS_PASSWORD=

# ─── Backend / FastAPI ───
BACKEND_DEBUG=true
BACKEND_LOG_LEVEL=INFO
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS (origenes del stack BACKUP) ───
CORS_ORIGINS=http://localhost:8081,http://localhost:5174,http://localhost:18001,http://localhost:8080,http://localhost:5173

# ─── AD / LDAP (igual que original) ───
LDAP_ENABLED=true
LDAP_SERVER=172.16.10.17
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN="OU=Oficina Central,DC=COFAR,DC=COM"
LDAP_BIND_USER=soporteglpi@cofar.com
LDAP_BIND_PASSWORD=glpi.1T.C0f4r
LDAP_USER_SEARCH_FILTER=(sAMAccountName={username})
LDAP_USER_SEARCH_BASE=OU=Oficina Central,DC=cofar,DC=com
LDAP_DOMAIN=cofar.com
LDAP_EXCLUDED_CNS=
LDAP_EXCLUDED_SAMACCOUNTNAMES=

# ─── Microsoft 365 / Graph ───
GRAPH_ENABLED=false
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
GRAPH_SCOPES=https://graph.microsoft.com/.default

# ─── SMTP (mailhog del stack BACKUP) ───
SMTP_ENABLED=false
SMTP_HOST=mailhog
SMTP_PORT=1026
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_EMAIL=noreply@cofar.local
SMTP_FROM_NAME=SGD COFAR (backup)

# ─── Rate limits ───
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_LOGIN=10
RATE_LIMIT_DOWNLOAD=30
