# ═══════════════════════════════════════════════════════════════
# COFAR SGD — Variables de entorno (DES / development)
# Copiar este archivo a .env y ajustar valores
# ═══════════════════════════════════════════════════════════════

# ─── Proyecto ───
PROJECT_NAME=cofar-sgd
ENVIRONMENT=development
TZ=America/La_Paz

# ─── Puertos host (NO deben chocar con los del sistema) ───
HOST_PORT_NGINX=8080
HOST_PORT_FRONTEND=5173
HOST_PORT_BACKEND=18000
HOST_PORT_POSTGRES=15432
HOST_PORT_REDIS=16379

# ─── PostgreSQL ───
POSTGRES_USER=sgd
POSTGRES_PASSWORD=sgd_dev_only_change_in_prod
POSTGRES_DB=sgd

# ─── Redis ───
REDIS_PASSWORD=

# ─── Backend / FastAPI ───
BACKEND_DEBUG=true
BACKEND_LOG_LEVEL=INFO
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Storage (Sesion 24 / F5) ───
# Ruta base donde el backend persiste archivos adjuntos a Documentos (R2).
# - DES: default /app/storage/uploads (volume del backend en docker-compose)
# - QAS: default /app/storage/uploads (volume)
# - DEV nativo en Windows: una ruta absoluta al disco local (ej: C:/path/to/storage/uploads)
# Compatible con STORAGE_ROOT (legacy, se respeta si esta definido).
DOCUMENTOS_STORAGE_PATH=/app/storage/uploads
# Ruta de las plantillas documentales (Sesion 24 / E1). El start-stack-des.bat
# copia los archivos desde backend/storage/plantillas/ al volumen del container.
PLANTILLAS_STORAGE_PATH=/app/storage/plantillas

# ─── CORS (orígenes permitidos para el frontend) ───
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:18000

# ─── AD / LDAP ───
# DES: LDAP_ENABLED=true porque el backend dentro de Docker ve la
#      VPN del host (networkingMode=mirrored en .wslconfig) y puede
#      llegar al RODC. Para desactivar y volver a stubs locales,
#      poner LDAP_ENABLED=false (los 4 usuarios dev son
#      aromero / solicitante / admin / visualizador con pass cofar.2026).
#
# QAS: en SRVQAS-SIGDOC (10.11.0.11) la unica DC accesible desde el
#      server es 10.10.0.2 por el puerto 389. La VPN de COFAR no
#      enruta al RODC 172.16.10.17 desde QAS, asi que hay que usar
#      la IP del DC interno directamente. Ver DECISIONES.md ADR-026.
#
#      LDAP_SERVER=10.10.0.2
#
# PRD: ajustar a la IP del DC que este en produccion. Si la red de
#      PROD tiene DNS completo de COFAR, se puede volver a usar
#      el nombre (dc3-cofar.com).
LDAP_ENABLED=true
LDAP_SERVER=172.16.10.17        # dc3-cofar.com (RODC, IP directa)
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=OU=Oficina Central,DC=COFAR,DC=COM
LDAP_BIND_USER=soporteglpi@cofar.com   # service account (NO password en este archivo)
LDAP_BIND_PASSWORD=                # completar en .env local
LDAP_USER_SEARCH_FILTER=(sAMAccountName={username})
LDAP_USER_SEARCH_BASE=OU=Oficina Central,DC=cofar,DC=com
LDAP_DOMAIN=cofar.com
# CNs excluidos del listado de impersonate (separados por coma).
# Si se deja vacio, se usan los 17 defaults definidos en ad_service.py
LDAP_EXCLUDED_CNS=
# sAMAccountNames excluidos (separados por coma, lowercase).
# Si se deja vacio, se usan los defaults (dlanchipa, ozegarra, visitador, visitador2, ajaimes)
LDAP_EXCLUDED_SAMACCOUNTNAMES=

# ─── Microsoft 365 / Graph (DES: stub. QAS: completar) ───
GRAPH_ENABLED=false
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
GRAPH_SCOPES=https://graph.microsoft.com/.default

# ─── SMTP (DES: stub mailhog. QAS: corporativo) ───
SMTP_ENABLED=false
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_EMAIL=noreply@cofar.local
SMTP_FROM_NAME=SGD COFAR

# ─── Rate limits (requests/minuto) ───
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_LOGIN=10
RATE_LIMIT_DOWNLOAD=30
