# ════════════════════════════════════════════════════════════════
# Backend .env.example (DESARROLLO)
# Este archivo es la plantilla. Copialo a .env (raíz del repo) y
# completá los valores. .env está en .gitignore, no se commitea.
# En Docker, las variables vienen del .env raíz vía docker-compose.
# Este archivo es para ejecución LOCAL sin Docker (opcional).
# ════════════════════════════════════════════════════════════════

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Cuando corras el backend localmente (sin Docker), apunta a localhost:
DATABASE_URL=postgresql+asyncpg://sgd:sgd_dev_only_change_in_prod@localhost:15432/sgd
REDIS_URL=redis://localhost:16379/0

JWT_SECRET=local-dev-secret-change-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:18000

# ─── LDAP / Active Directory ───
# En DES con VPN a rodc.cofar.com.bo: poner LDAP_ENABLED=true y la password real.
# En DES sin VPN: dejar LDAP_ENABLED=false y usar la password dummy `cofar.2026` contra los 4 stubs.
# En QAS: LDAP_ENABLED=true con la password real rotada.
LDAP_ENABLED=false
LDAP_SERVER=rodc.cofar.com.bo
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=DC=cofar,DC=com
LDAP_DOMAIN=cofar.com
LDAP_BIND_USER=soporteglpi@cofar.com
# La password va SOLO en el .env local (NO en el repo, NO en .env.example)
LDAP_BIND_PASSWORD=
LDAP_USER_SEARCH_FILTER=(sAMAccountName={username})
LDLDAP_USER_SEARCH_BASE=OU=Oficina Central,DC=cofar,DC=com
# CNs y sAMAccountNames excluidos del listado de impersonate.
# Vacío = usar los 17 defaults hardcoded en app/services/ad_service.py.
LDAP_EXCLUDED_CNS=
LDAP_EXCLUDED_SAMACCOUNTNAMES=

# ─── Microsoft Graph (futuro R4) ───
GRAPH_ENABLED=false
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
GRAPH_SCOPES=https://graph.microsoft.com/.default

# ─── SMTP ───
# En DES usamos MailHog (stub local), SMTP_ENABLED=false para no enviar real.
SMTP_ENABLED=false
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_EMAIL=noreply@cofar.local
SMTP_FROM_NAME=SGD COFAR

# ─── Rate limits ───
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_LOGIN=10
RATE_LIMIT_DOWNLOAD=30
